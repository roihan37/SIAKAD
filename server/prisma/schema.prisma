// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  username    String   @unique
  password    String
  role        Role

  phoneNumber String?
  photo       String?
  address     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mahasiswa   Mahasiswa?
  dosen       Dosen?
}

model Mahasiswa {
  id          String   @id @default(uuid())

  nim         String   @unique

  angkatan    Int
  semester    Int

  status      Status

  userId      String   @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  prodiId     Int
  prodi        Prodi   @relation(fields: [prodiId], references: [id])

  dosenId     String?
  dosen        Dosen?  @relation(fields: [dosenId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dosen {
  id          String   @id @default(uuid())

  nidn        String   @unique

  status      Status
  jabatan     JabatanDosen @default(DOSEN)

  userId      String   @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  prodiId     Int
  prodi        Prodi   @relation(fields: [prodiId], references: [id])

  mahasiswa   Mahasiswa[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fakultas {
  id          Int      @id @default(autoincrement())
  kode        String   @unique
  nama        String

  prodi       Prodi[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Prodi {
  id          Int      @id @default(autoincrement())
  kode        String   @unique
  nama        String

  fakultasId  Int
  fakultas    Fakultas @relation(fields: [fakultasId], references: [id])

  dosen       Dosen[]
  mahasiswa   Mahasiswa[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  DOSEN
  MAHASISWA
}

enum Status {
  AKTIF
  CUTI
  LULUS
  NONAKTIF
}

enum JabatanDosen {
  DOSEN
  KAPRODI
  DEKAN
  REKTOR
}